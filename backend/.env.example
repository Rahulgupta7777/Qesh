PORT=3000
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/qesh?retryWrites=true&w=majority
JWT_SECRET=your_super_secret_jwt_key_here
SUPER_ADMIN_EMAIL=admin@qesh.app
NODE_ENV=development

# WhatsApp Business API (Optional - falls back to console logging in dev mode)
WHATSAPP_PHONE_ID=your_whatsapp_phone_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token

# Pixabay Image Search (Optional)
PIXABAY_KEY=your_pixabay_api_key
